# Copy to project root as .env.local (same variable names).

# Backend for lead forms. Must be full https URL, no trailing slash.
# If omitted, default https://server-nu-bay-20.vercel.app is used (override for your API).
NEXT_PUBLIC_API_URL=
# Local dev: set this to Nest (e.g. http://localhost:3000). Run Next on another port: npm run dev (default 3001).
# Optional: canonical public URL (no trailing slash). Overrides auto-detection.
# If unset: Vercel sets VERCEL_URL at build time; else falls back to http://localhost:3000
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
# Phone is fixed in app/config/publicEnv.ts (PUBLIC_CONTACT_PHONE). This key is unused.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
NEXT_PUBLIC_INDIA_MAP_SVG_URL=
NEXT_PUBLIC_INDIA_MAP_FALLBACK_SVG_URL=

# Supabase — home slider reads public.services (is_active = true). Optional: if unset, static fallback is used.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Supabase service role (site data). Admin login uses NEXT_PUBLIC_API_URL + POST /api/auth/login.
SUPABASE_SERVICE_ROLE_KEY=
# Random string, min 16 chars — signs admin session cookie (httpOnly).
ADMIN_SESSION_SECRET=
# Optional (local dev only): prefills /admin/login inputs; production builds ignore these.
# NEXT_PUBLIC_ADMIN_LOGIN_PREFILL_EMAIL=
# NEXT_PUBLIC_ADMIN_LOGIN_PREFILL_PASSWORD=
